{
  "name": "timer-up",
  "version": "1.0.0",
  "description": "Visual countdown timer for kids",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "clean": "rm -rf dist",
    "dist": "npm run clean && electron-builder && npm run dist:cleanup",
    "dist:win": "npm run clean && electron-builder --win && npm run dist:cleanup",
    "dist:mac": "npm run clean && electron-builder --mac && npm run dist:cleanup",
    "dist:all": "npm run clean && electron-builder --mac --win && npm run dist:cleanup",
    "dist:cleanup": "rm -rf dist/*-unpacked dist/builder-*.y*ml dist/builder-*.yaml"
  },
  "author": "Tengelin",
  "license": "ISC",
  "build": {
    "appId": "com.tengelin.timer-up",
    "productName": "TimerUp",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "styles/**/*",
      "scripts/**/*",
      "audio/**/*",
      "icons/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icons/icon.icns"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "publish": null
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.0.12"
  }
}
