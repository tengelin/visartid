{
  "name": "timer-up",
  "version": "2.0.0",
  "description": "Visual countdown timer — web app & Chrome/Edge extension",
  "type": "module",
  "scripts": {
    "start": "node scripts/serve.js",
    "test": "vitest run",
    "lint": "eslint . && stylelint 'styles/**/*.css' 'extension/**/*.css'",
    "lint:fix": "eslint . --fix && stylelint 'styles/**/*.css' 'extension/**/*.css' --fix",
    "posttest": "npm run lint",
    "clean": "rm -rf dist",
    "pack:extension": "node scripts/pack-extension.js"
  },
  "author": "Tengelin",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/stylelint-config": "^3.0.1",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "vitest": "^4.1.2"
  }
}
